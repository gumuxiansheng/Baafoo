{
  "name": "gRPC Client Streaming - CollectMetrics",
  "protocol": "grpc",
  "host": "metrics.example.com",
  "port": 50051,
  "enabled": true,
  "priority": 100,
  "conditions": [
    {
      "type": "grpcService",
      "operator": "equals",
      "value": "metrics.MetricsCollector"
    },
    {
      "type": "grpcMethod",
      "operator": "equals",
      "value": "CollectMetrics"
    }
  ],
  "responses": [
    {
      "name": "聚合指标响应",
      "statusCode": 200,
      "headers": {
        "grpc-status": "0"
      },
      "body": "{\"totalCount\":3,\"average\":50.0,\"summary\":\"Collected 3 metrics\"}",
      "delayMs": 0
    }
  ],
  "environments": []
}
