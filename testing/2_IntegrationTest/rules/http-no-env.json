{
  "id": "staging-http-global",
  "name": "HTTP Global Rule (No Environment)",
  "protocol": "http",
  "host": "real-backend",
  "port": 9090,
  "conditions": [
    {
      "type": "path",
      "operator": "equals",
      "value": "/global-endpoint"
    }
  ],
  "responses": [
    {
      "name": "Global Response",
      "statusCode": 200,
      "body": "{\"mocked\":true,\"protocol\":\"http\",\"rule\":\"global\"}",
      "delayMs": 0
    }
  ],
  "enabled": true,
  "priority": 100,
  "tags": [
    "http",
    "global",
    "no-env"
  ],
  "environments": []
}
