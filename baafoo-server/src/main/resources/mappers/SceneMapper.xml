<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.baafoo.server.mapper.SceneMapper">

    <resultMap id="SceneResultMap" type="SceneEntity">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="description" column="description"/>
        <result property="itemIdsJson" column="item_ids_json"/>
        <result property="active" column="active"/>
        <result property="tagsJson" column="tags_json"/>
        <result property="environmentsJson" column="environments_json"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="selectAll" resultMap="SceneResultMap">
        SELECT * FROM scene_sets
    </select>

    <select id="selectById" resultMap="SceneResultMap">
        SELECT * FROM scene_sets WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="SceneEntity">
        INSERT INTO scene_sets (id, name, description, item_ids_json, active,
            tags_json, environments_json, created_at, updated_at)
        VALUES (#{id}, #{name}, #{description}, #{itemIdsJson}, #{active},
            #{tagsJson}, #{environmentsJson}, #{createdAt}, #{updatedAt})
    </insert>

    <update id="update" parameterType="SceneEntity">
        UPDATE scene_sets SET
            name = #{name},
            description = #{description},
            item_ids_json = #{itemIdsJson},
            active = #{active},
            tags_json = #{tagsJson},
            environments_json = #{environmentsJson},
            updated_at = #{updatedAt}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM scene_sets WHERE id = #{id}
    </delete>

</mapper>
