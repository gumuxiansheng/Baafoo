# =============================================================================
# Baafoo Test Spring Dockerfile — Multi-Agent (JaCoCo + SkyWalking + Baafoo)
#
# Same as base Dockerfile but with JaCoCo + SkyWalking agents attached.
# Agent load order: jacoco → skywalking → baafoo (recommended order)
# =============================================================================

FROM eclipse-temurin:8-jre-alpine

LABEL maintainer="Baafoo Multi-Agent Test"

RUN apk add --no-cache tzdata && \
    cp /usr/share/zoneinfo/Asia/Shanghai /etc/localtime && \
    echo "Asia/Shanghai" > /etc/timezone && \
    apk del tzdata

RUN addgroup -S baafoo && adduser -S baafoo -G baafoo

WORKDIR /app

# Copy application jar
COPY baafoo-test-spring/target/baafoo-test-spring-*.jar ./baafoo-test-spring.jar

# Copy Baafoo agent
COPY baafoo-agent/target/baafoo-agent-*.jar ./baafoo-agent.jar
COPY baafoo-agent/src/main/resources/baafoo-agent.yml ./baafoo-agent.yml

# Agent directories (JARs mounted via docker-compose volumes)
# Create directories so volume mounts have targets
RUN mkdir -p /app/agents /home/baafoo/.baafoo/data /tmp/jacoco/classdumps && \
    chown -R baafoo:baafoo /app /home/baafoo/.baafoo /tmp/jacoco

USER baafoo

EXPOSE 9090 6300

ENV JAVA_OPTS="" \
    BAAFOO_SERVER_HOST="server" \
    BAAFOO_ENV="staging-a" \
    SERVER_PORT=9090 \
    SW_AGENT_NAME="service-consumer" \
    SW_AGENT_COLLECTOR_BACKEND_SERVICES="skywalking-oap:11800" \
    JACOCO_PORT=6300

# Launch with three agents: JaCoCo → SkyWalking → Baafoo
ENTRYPOINT ["sh", "-c", \
    "java ${JAVA_OPTS} \
     -javaagent:/app/agents/jacoco-agent.jar=output=tcpserver,address=0.0.0.0,port=${JACOCO_PORT},append=true,classdumpdir=/tmp/jacoco/classdumps \
     -javaagent:/app/agents/skywalking/skywalking-agent.jar \
     -javaagent:/app/baafoo-agent.jar=config=/app/baafoo-agent.yml \
     -jar /app/baafoo-test-spring.jar \
     --server.port=${SERVER_PORT}"]
