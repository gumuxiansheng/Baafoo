# =============================================================================
# Baafoo 企业级 Spring Cloud Gateway 测试 - Gateway 应用 Dockerfile
# 基于自构建的 Spring Cloud Gateway 应用 (替换不存在的官方镜像)，注入 Baafoo Agent
# =============================================================================

FROM eclipse-temurin:17-jre-alpine

LABEL maintainer="Baafoo Enterprise Gateway Test"

# Alpine: 安装 wget 用于 healthcheck
RUN apk add --no-cache wget

WORKDIR /app

COPY baafoo-agent/target/baafoo-agent-*.jar /app/baafoo-agent.jar
COPY testing/4_E2ETest/enterprise/spring-cloud-gateway/baafoo-agent-gateway.yml /app/baafoo-agent.yml
COPY testing/4_E2ETest/enterprise/spring-cloud-gateway/baafoo-gateway-test/target/baafoo-gateway-test.jar /app/baafoo-gateway-test.jar

RUN mkdir -p /root/.baafoo/data

EXPOSE 8080

ENV JAVA_OPTS="-XX:-UseContainerSupport -Xms128m -Xmx256m --add-opens java.base/java.net=ALL-UNNAMED" \
    BAAFOO_SERVER_HOST="baafoo-server" \
    BAAFOO_ENV="enterprise-gateway"

# 路由配置已内置于 application.yml，BACKEND_HOST/BACKEND_PORT 通过环境变量覆盖
ENTRYPOINT ["sh", "-c", \
    "java ${JAVA_OPTS} \
     -javaagent:/app/baafoo-agent.jar=config=/app/baafoo-agent.yml \
     -jar /app/baafoo-gateway-test.jar \
     --server.port=8080"]
