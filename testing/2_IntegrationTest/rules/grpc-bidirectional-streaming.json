{
  "id": "grpc-bidirectional-streaming",
  "name": "gRPC Bidirectional Streaming - Chat",
  "protocol": "grpc",
  "host": "chat.example.com",
  "port": 50051,
  "enabled": true,
  "priority": 100,
  "conditions": [
    {
      "type": "grpcService",
      "operator": "equals",
      "value": "chat.ChatService"
    },
    {
      "type": "grpcMethod",
      "operator": "equals",
      "value": "Chat"
    }
  ],
  "responses": [
    {
      "name": "聊天响应流",
      "statusCode": 200,
      "headers": {
        "grpc-status": "0"
      },
      "body": "{\"message\":\"Echo: hello\"},{\"message\":\"Echo: world\"}",
      "delayMs": 100
    }
  ],
  "environments": []
}
