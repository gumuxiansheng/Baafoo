<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.baafoo.server.mapper.EnvironmentMapper">

    <resultMap id="EnvironmentResultMap" type="EnvironmentEntity">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="mode" column="mode"/>
        <result property="agentIdsJson" column="agent_ids_json"/>
        <result property="variablesJson" column="variables_json"/>
        <result property="metadataJson" column="metadata_json"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="selectAll" resultMap="EnvironmentResultMap">
        SELECT * FROM environments
    </select>

    <select id="selectById" resultMap="EnvironmentResultMap">
        SELECT * FROM environments WHERE id = #{id}
    </select>

    <select id="selectByName" resultMap="EnvironmentResultMap">
        SELECT * FROM environments WHERE name = #{name}
    </select>

    <insert id="insert" parameterType="EnvironmentEntity">
        INSERT INTO environments (id, name, mode, agent_ids_json, variables_json,
            metadata_json, created_at, updated_at)
        VALUES (#{id}, #{name}, #{mode}, #{agentIdsJson}, #{variablesJson},
            #{metadataJson}, #{createdAt}, #{updatedAt})
    </insert>

    <update id="update" parameterType="EnvironmentEntity">
        UPDATE environments SET
            name = #{name},
            mode = #{mode},
            agent_ids_json = #{agentIdsJson},
            variables_json = #{variablesJson},
            metadata_json = #{metadataJson},
            updated_at = #{updatedAt}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM environments WHERE id = #{id}
    </delete>

</mapper>
