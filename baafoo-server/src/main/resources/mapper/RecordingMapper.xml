<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.baafoo.server.storage.mapper.RecordingMapper">

    <resultMap id="recordingResultMap" type="com.baafoo.core.model.RecordingEntry">
        <id property="id" column="id"/>
        <result property="ruleId" column="rule_id"/>
        <result property="environmentId" column="environment_id"/>
        <result property="agentId" column="agent_id"/>
        <result property="agentIp" column="agent_ip"/>
        <result property="protocol" column="protocol"/>
        <result property="host" column="host"/>
        <result property="port" column="port"/>
        <result property="serviceName" column="service_name"/>
        <result property="method" column="method"/>
        <result property="path" column="path"/>
        <result property="requestBody" column="request_body"/>
        <result property="responseStatusCode" column="response_status_code"/>
        <result property="responseBody" column="response_body"/>
        <result property="responseTimeMs" column="response_time_ms"/>
        <result property="recordedAt" column="recorded_at"/>
        <result property="requestHeaders" column="request_headers_json"
                typeHandler="com.baafoo.server.storage.mybatis.JsonTypeHandler"
                javaType="java.util.Map"/>
        <result property="responseHeaders" column="response_headers_json"
                typeHandler="com.baafoo.server.storage.mybatis.JsonTypeHandler"
                javaType="java.util.Map"/>
        <result property="tags" column="tags_json"
                typeHandler="com.baafoo.server.storage.mybatis.JsonTypeHandler"
                javaType="java.util.Map"/>
        <result property="direction" column="direction"/>
        <result property="sessionId" column="session_id"/>
        <result property="dataHex" column="data_hex"/>
        <result property="durationMs" column="duration_ms"/>
    </resultMap>

    <sql id="searchConditions">
        <where>
            <if test="ruleId != null and ruleId != ''">
                AND rule_id = #{ruleId}
            </if>
            <if test="agentId != null and agentId != ''">
                AND agent_id = #{agentId}
            </if>
            <if test="agentIp != null and agentIp != ''">
                AND agent_ip LIKE '%' || #{agentIp} || '%'
            </if>
            <if test="protocol != null and protocol != ''">
                AND protocol = #{protocol}
            </if>
            <if test="method != null and method != ''">
                AND method = #{method}
            </if>
            <if test="path != null and path != ''">
                AND path LIKE '%' || #{path} || '%'
            </if>
            <if test="statusCode != null">
                AND response_status_code = #{statusCode}
            </if>
            <!-- PostgreSQL: full-text search using tsvector + GIN index -->
            <if test="keyword != null and keyword != '' and _databaseId == 'postgresql'">
                AND search_vector @@ plainto_tsquery('pg_catalog.english', #{keyword})
            </if>
            <!-- H2: full-text search using built-in FT index -->
            <if test="keyword != null and keyword != '' and _databaseId == 'h2'">
                AND id IN (SELECT KEYS[1] FROM FT_SEARCH_DATA(#{keyword}, 0, 0))
            </if>
            <!-- Other databases: LIKE fallback -->
            <if test="keyword != null and keyword != '' and _databaseId != 'postgresql' and _databaseId != 'h2'">
                AND (request_body LIKE '%' || #{keyword} || '%'
                     OR response_body LIKE '%' || #{keyword} || '%'
                     OR path LIKE '%' || #{keyword} || '%'
                     OR request_headers_json LIKE '%' || #{keyword} || '%'
                     OR response_headers_json LIKE '%' || #{keyword} || '%')
            </if>
        </where>
    </sql>

    <select id="listRecordings" resultMap="recordingResultMap">
        SELECT * FROM recordings
        <if test="ruleId != null and ruleId != ''">
            WHERE rule_id = #{ruleId}
        </if>
        ORDER BY recorded_at DESC LIMIT #{limit}
    </select>

    <select id="countRecordings" resultType="long">
        SELECT COUNT(*) FROM recordings
        <include refid="searchConditions"/>
    </select>

    <select id="listRecordingsPaged" resultMap="recordingResultMap">
        SELECT * FROM recordings
        <include refid="searchConditions"/>
        ORDER BY recorded_at DESC LIMIT #{limit} OFFSET #{offset}
    </select>

    <insert id="insertRecording">
        INSERT INTO recordings (id, rule_id, environment_id, agent_id, agent_ip, protocol,
            host, port, service_name, method, path, request_headers_json, request_body,
            response_status_code, response_headers_json, response_body, response_time_ms,
            recorded_at, tags_json, direction, session_id, data_hex, duration_ms)
        VALUES (#{id}, #{ruleId}, #{environmentId}, #{agentId}, #{agentIp}, #{protocol},
            #{host}, #{port}, #{serviceName}, #{method}, #{path},
            #{requestHeaders, typeHandler=com.baafoo.server.storage.mybatis.JsonTypeHandler},
            #{requestBody},
            #{responseStatusCode},
            #{responseHeaders, typeHandler=com.baafoo.server.storage.mybatis.JsonTypeHandler},
            #{responseBody}, #{responseTimeMs}, #{recordedAt},
            #{tags, typeHandler=com.baafoo.server.storage.mybatis.JsonTypeHandler},
            #{direction}, #{sessionId}, #{dataHex}, #{durationMs})
    </insert>

    <!-- Trim recordings - H2 dialect -->
    <delete id="trimRecordings" databaseId="h2">
        DELETE FROM recordings WHERE id NOT IN
            (SELECT id FROM recordings ORDER BY recorded_at DESC LIMIT #{keepCount})
    </delete>

    <!-- Trim recordings - PostgreSQL dialect -->
    <delete id="trimRecordings" databaseId="postgresql">
        DELETE FROM recordings WHERE id NOT IN
            (SELECT id FROM recordings ORDER BY recorded_at DESC LIMIT #{keepCount})
    </delete>

    <delete id="deleteRecording">
        DELETE FROM recordings WHERE id = #{id}
    </delete>

    <delete id="deleteRecordingsOlderThan">
        DELETE FROM recordings WHERE recorded_at &lt; #{cutoffTime}
    </delete>

    <select id="countAllRecordings" resultType="long">
        SELECT COUNT(*) FROM recordings
    </select>

    <select id="sumAllRecordingBodyBytes" resultType="long">
        SELECT COALESCE(SUM(
            COALESCE(LENGTH(response_body), 0) + COALESCE(LENGTH(request_body), 0)
        ), 0) FROM recordings
    </select>

    <select id="listOldestRecordings" resultMap="recordingResultMap">
        SELECT * FROM recordings ORDER BY recorded_at ASC LIMIT #{limit}
    </select>

    <!-- Recordings count by day for the last N days -->
    <select id="countRecordingsByDay" resultType="map">
        SELECT
            CAST(FLOOR(recorded_at / 86400000) * 86400000 AS BIGINT) AS day,
            COUNT(*) AS count
        FROM recordings
        WHERE recorded_at >= #{startTime}
        GROUP BY FLOOR(recorded_at / 86400000)
        ORDER BY day ASC
    </select>

</mapper>
