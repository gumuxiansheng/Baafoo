<?xml version="1.0" encoding="UTF-8"?>
<toolchains>
    <!-- JDK 8 — required for Baafoo compilation (target: 1.8) -->
    <!-- Copy this file to ~/.m2/toolchains.xml and adjust jdkHome -->
    <toolchain>
        <type>jdk</type>
        <provides>
            <version>1.8</version>
        </provides>
        <configuration>
            <jdkHome>C:\Program Files\Java\jdk1.8.0_202</jdkHome>
        </configuration>
    </toolchain>
</toolchains>
