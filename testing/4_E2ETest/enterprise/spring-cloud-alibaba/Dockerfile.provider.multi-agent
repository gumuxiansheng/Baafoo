# =============================================================================
# Spring Cloud Alibaba Provider Dockerfile (Multi-Agent: JaCoCo + SkyWalking + Baafoo)
# Build context: c:\Dev\Projects\Baafoo
# =============================================================================

FROM eclipse-temurin:17-jre-alpine

LABEL maintainer="Baafoo Multi-Agent Test"

RUN apk add --no-cache tzdata wget && \
    cp /usr/share/zoneinfo/Asia/Shanghai /etc/localtime && \
    echo "Asia/Shanghai" > /etc/timezone && \
    apk del tzdata

RUN addgroup -S baafoo && adduser -S baafoo -G baafoo

WORKDIR /app

# Copy application jar
COPY testing/enterprise/spring-cloud-alibaba/baafoo-sca-test/baafoo-sca-provider/target/baafoo-sca-provider.jar ./app.jar

# Copy Baafoo agent
COPY baafoo-agent/target/baafoo-agent-*.jar ./baafoo-agent.jar
COPY testing/enterprise/spring-cloud-alibaba/baafoo-agent-provider.yml ./baafoo-agent.yml

# Copy JaCoCo agent
COPY testing/enterprise/spring-cloud-alibaba/agents/jacoco-agent.jar ./agents/jacoco-agent.jar

# Copy SkyWalking agent
COPY testing/enterprise/spring-cloud-alibaba/agents/skywalking-agent ./agents/skywalking

RUN mkdir -p /home/baafoo/.baafoo/data /tmp/jacoco/classdumps && \
    chown -R baafoo:baafoo /app /home/baafoo/.baafoo /tmp/jacoco

USER baafoo

EXPOSE 18081 6301

ENV JAVA_OPTS="-XX:-UseContainerSupport -Xms256m -Xmx512m -XX:MaxMetaspaceSize=256m" \
    BAAFOO_SERVER_HOST="baafoo-server" \
    BAAFOO_ENV="enterprise-sca-provider" \
    SERVER_PORT=18081 \
    NACOS_ADDR="nacos:8848" \
    NACOS_USER="nacos" \
    NACOS_PASS="nacos" \
    NACOS_REGISTER_HOST="service-provider" \
    SW_AGENT_NAME="service-provider" \
    SW_AGENT_COLLECTOR_BACKEND_SERVICES="baafoo-enterprise-oap:11800" \
    JACOCO_PORT=6301

ENTRYPOINT ["sh", "-c", \
    "java ${JAVA_OPTS} \
     -javaagent:/app/agents/jacoco-agent.jar=output=tcpserver,address=0.0.0.0,port=${JACOCO_PORT},append=true,classdumpdir=/tmp/jacoco/classdumps \
     -javaagent:/app/agents/skywalking/skywalking-agent.jar \
     -javaagent:/app/baafoo-agent.jar=config=/app/baafoo-agent.yml \
     -jar /app/app.jar \
     --server.port=${SERVER_PORT} \
     --spring.cloud.nacos.discovery.server-addr=${NACOS_ADDR} \
     --spring.cloud.nacos.discovery.username=${NACOS_USER} \
     --spring.cloud.nacos.discovery.password=${NACOS_PASS} \
     --spring.cloud.nacos.discovery.ip=${NACOS_REGISTER_HOST}"]
