  {
    "id": "staging-a-http-get",
    "name": "HTTP GET挡板",
    "protocol": "http",
    "host": "real-backend",
    "port": 9090,
    "conditions": [
      {
        "type": "method",
        "operator": "equals",
        "value": "GET"
      },
      {
        "type": "path",
        "operator": "startsWith",
        "value": "/"
      }
    ],
    "responses": [
      {
        "name": "GET响应",
        "statusCode": 200,
        "headers": {
          "X-Baafoo-Method": "GET"
        },
        "body": "{\"mocked\":true,\"env\":\"staging-a\",\"protocol\":\"http\",\"method\":\"GET\",\"path\":\"{{request.path}}\"}",
        "delayMs": 0
      }
    ],
    "enabled": true,
    "priority": 100,
    "tags": [
      "http",
      "staging-a"
    ],
    "environments": [
      "staging-a"
    ]
  },
