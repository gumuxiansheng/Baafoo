<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.baafoo.server.mapper.UserMapper">

    <resultMap id="UserResultMap" type="UserEntity">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="passwordHash" column="password_hash"/>
        <result property="displayName" column="display_name"/>
        <result property="email" column="email"/>
        <result property="role" column="role"/>
        <result property="apiKey" column="api_key"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="lastLoginAt" column="last_login_at"/>
    </resultMap>

    <select id="selectAll" resultMap="UserResultMap">
        SELECT * FROM users ORDER BY created_at ASC
    </select>

    <select id="selectByUsername" resultMap="UserResultMap">
        SELECT * FROM users WHERE username = #{username}
    </select>

    <select id="selectByApiKey" resultMap="UserResultMap">
        SELECT * FROM users WHERE api_key = #{apiKey}
    </select>

    <insert id="insert" parameterType="UserEntity">
        INSERT INTO users (id, username, password_hash, display_name, email, role, api_key, created_at, updated_at, last_login_at)
        VALUES (#{id}, #{username}, #{passwordHash}, #{displayName}, #{email}, #{role}, #{apiKey}, #{createdAt}, #{updatedAt}, #{lastLoginAt})
    </insert>

    <update id="updateRole">
        UPDATE users SET role = #{role}, updated_at = CURRENT_TIMESTAMP WHERE username = #{username}
    </update>

    <update id="updateApiKey">
        UPDATE users SET api_key = #{apiKey}, updated_at = CURRENT_TIMESTAMP WHERE username = #{username}
    </update>

    <update id="updateLastLogin">
        UPDATE users SET last_login_at = #{lastLoginAt} WHERE username = #{username}
    </update>

    <delete id="deleteByUsername">
        DELETE FROM users WHERE username = #{username}
    </delete>

</mapper>
