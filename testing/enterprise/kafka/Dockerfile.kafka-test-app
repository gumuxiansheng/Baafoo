# =============================================================================
# Baafo 企业级 Kafka 测试应用 Dockerfile
# 复用 baafoo-test-spring 测试应用，但 COPY Kafka 专用 Agent 配置
# 直接嵌入镜像以避免 Windows Docker Desktop 单文件 volume 挂载问题
# =============================================================================

FROM eclipse-temurin:8-jre-alpine

LABEL maintainer="Baafoo Enterprise Kafka Test"

RUN apk add --no-cache tzdata && \
    cp /usr/share/zoneinfo/Asia/Shanghai /etc/localtime && \
    echo "Asia/Shanghai" > /etc/timezone && \
    apk del tzdata

RUN addgroup -S baafoo && adduser -S baafoo -G baafoo

WORKDIR /app

# 复制本地构建好的 JAR 文件
COPY baafoo-test-spring/target/baafoo-test-spring-*.jar ./baafoo-test-spring.jar
COPY baafoo-agent/target/baafoo-agent-*.jar ./baafoo-agent.jar

# 复制 Kafka 专用 Agent 配置（不再通过 volume 挂载）
COPY testing/enterprise/kafka/baafoo-agent-kafka.yml ./baafoo-agent.yml

RUN mkdir -p /home/baafoo/.baafoo/data && \
    chown -R baafoo:baafoo /app /home/baafoo/.baafoo

USER baafoo

EXPOSE 9090

ENV JAVA_OPTS="" \
    BAAFOO_SERVER_HOST="baafoo-server" \
    BAAFOO_ENV="enterprise-kafka" \
    SERVER_PORT=9090

# 以 Agent 模式启动 Spring Boot 测试应用
ENTRYPOINT ["sh", "-c", \
    "java ${JAVA_OPTS} \
     -javaagent:/app/baafoo-agent.jar=config=/app/baafoo-agent.yml \
     -jar /app/baafoo-test-spring.jar \
     --server.port=${SERVER_PORT}"]
