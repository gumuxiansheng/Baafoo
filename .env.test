# =============================================================================
# Baafoo 集成测试环境变量
# =============================================================================

# 数据库模式: h2 (默认) 或 postgresql
BAAFOO_DB_TYPE=h2

# PostgreSQL 连接 (使用服务名，不是 localhost)
BAAFOO_DB_URL=jdbc:postgresql://postgres:5432/baafoo
BAAFOO_DB_USERNAME=baafoo
BAAFOO_DB_PASSWORD=baafoo

# Server 端口
BAAFOO_HTTP_PORT=8084

# JVM
JAVA_OPTS=-Xms256m -Xmx512m
