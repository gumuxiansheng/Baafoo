# =============================================================================
# Baafo 浼佷笟绾?Kafka 娴嬭瘯搴旂敤 Dockerfile
# 澶嶇敤 baafoo-test-spring 娴嬭瘯搴旂敤锛屼絾 COPY Kafka 涓撶敤 Agent 閰嶇疆
# 鐩存帴宓屽叆闀滃儚浠ラ伩鍏?Windows Docker Desktop 鍗曟枃浠?volume 鎸傝浇闂
# =============================================================================

FROM eclipse-temurin:8-jre-alpine

LABEL maintainer="Baafoo Enterprise Kafka Test"

RUN apk add --no-cache tzdata wget && \
    cp /usr/share/zoneinfo/Asia/Shanghai /etc/localtime && \
    echo "Asia/Shanghai" > /etc/timezone && \
    apk del tzdata

RUN addgroup -S baafoo && adduser -S baafoo -G baafoo

WORKDIR /app

# 澶嶅埗鏈湴鏋勫缓濂界殑 JAR 鏂囦欢
COPY baafoo-test-spring/target/baafoo-test-spring-*.jar ./baafoo-test-spring.jar
COPY baafoo-agent/target/baafoo-agent-*.jar ./baafoo-agent.jar

# 澶嶅埗 Kafka 涓撶敤 Agent 閰嶇疆锛堜笉鍐嶉€氳繃 volume 鎸傝浇锛?COPY testing/4_E2ETest/enterprise/kafka/baafoo-agent-kafka.yml ./baafoo-agent.yml

RUN mkdir -p /home/baafoo/.baafoo/data && \
    chown -R baafoo:baafoo /app /home/baafoo/.baafoo

USER baafoo

EXPOSE 9090

ENV JAVA_OPTS="" \
    BAAFOO_SERVER_HOST="baafoo-server" \
    BAAFOO_ENV="enterprise-kafka" \
    SERVER_PORT=9090

# 浠?Agent 妯″紡鍚姩 Spring Boot 娴嬭瘯搴旂敤
ENTRYPOINT ["sh", "-c", \
    "java ${JAVA_OPTS} \
     -javaagent:/app/baafoo-agent.jar=config=/app/baafoo-agent.yml \
     -jar /app/baafoo-test-spring.jar \
     --server.port=${SERVER_PORT}"]
