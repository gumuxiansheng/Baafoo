{
  "id": "staging-a-http-jsonpath",
  "name": "HTTP Body JsonPath Match",
  "protocol": "http",
  "host": "real-backend",
  "port": 9090,
  "conditions": [
    {
      "type": "path",
      "operator": "startsWith",
      "value": "/post"
    },
    {
      "type": "bodyJsonPath",
      "operator": "equals",
      "key": "$.action",
      "value": "submit"
    }
  ],
  "responses": [
    {
      "name": "JsonPath Matched",
      "statusCode": 200,
      "body": "{\"mocked\":true,\"protocol\":\"http\",\"matchedBy\":\"jsonPath\"}",
      "delayMs": 0
    }
  ],
  "enabled": true,
  "priority": 5,
  "tags": [
    "http",
    "jsonpath",
    "staging-a"
  ],
  "environments": [
    "staging-a"
  ]
}
