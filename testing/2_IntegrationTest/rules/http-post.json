{
  "id": "staging-a-http-post",
  "name": "HTTP POST",
  "protocol": "http",
  "host": "real-backend",
  "port": 9090,
  "conditions": [
    {
      "type": "method",
      "operator": "equals",
      "value": "POST"
    },
    {
      "type": "path",
      "operator": "startsWith",
      "value": "/"
    }
  ],
  "responses": [
    {
      "name": "POST",
      "statusCode": 201,
      "headers": {
        "X-Baafoo-Method": "POST"
      },
      "body": "{\"mocked\":true,\"env\":\"{{environment}}\",\"protocol\":\"http\",\"method\":\"POST\",\"requestBody\":\"{{request.body}}\"}",
      "delayMs": 0
    }
  ],
  "enabled": true,
  "priority": 100,
  "tags": [
    "http",
    "staging-a"
  ],
  "environments": [
    "staging-a"
  ]
}
