          "name": "登录响应",
          "statusCode": 200,
          "body": "LOGIN-OK",
          "delayMs": 0
        }
      },
      {
        "pattern": ".*QUERY.*",
        "response": {
          "name": "查询响应",
          "statusCode": 200,
          "body": "QUERY-RESULT-DATA",
          "delayMs": 0
        }
      },
      {
        "pattern": ".*LOGOUT.*",
        "response": {
          "name": "登出响应",
          "statusCode": 200,
