{
  "id": "grpc-greeter",
  "name": "gRPC Greeter SayHello",
  "protocol": "grpc",
  "host": "greeter.example.com",
  "port": 50051,
  "enabled": true,
  "priority": 100,
  "conditions": [
    {
      "type": "grpcService",
      "operator": "equals",
      "value": "helloworld.Greeter"
    },
    {
      "type": "grpcMethod",
      "operator": "equals",
      "value": "SayHello"
    }
  ],
  "responses": [
    {
      "name": "成功响应",
      "statusCode": 200,
      "headers": {
        "grpc-status": "0",
        "grpc-message": "OK"
      },
      "body": "{\"message\":\"Hello Baafoo gRPC\"}",
      "delayMs": 0
    }
  ],
  "environments": []
}
