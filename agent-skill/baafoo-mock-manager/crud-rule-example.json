  "responses": [
    {
      "statusCode": 200,
      "headers": {"Content-Type": "application/json"},
      "body": "{\"id\":1,\"name\":\"Alice\",\"email\":\"alice@example.com\"}"
    }
  ],
  "priority": 50,
  "tags": ["user", "crud"],
  "environments": ["dev"]
}
