{
  "id": "staging-a-http-caseinsensitive",
  "name": "HTTP Case Insensitive",
  "protocol": "http",
  "host": "real-backend",
  "port": 9090,
  "conditions": [
    {
      "type": "path",
      "operator": "equals",
      "value": "/CASE-TEST",
      "caseSensitive": false
    }
  ],
  "responses": [
    {
      "name": "Case Insensitive Match",
      "statusCode": 200,
      "body": "{\"mocked\":true,\"protocol\":\"http\",\"matchedBy\":\"case-insensitive\"}",
      "delayMs": 0
    }
  ],
  "enabled": true,
  "priority": 10,
  "tags": [
    "http",
    "case-insensitive",
    "staging-a"
  ],
  "environments": [
    "staging-a"
  ]
}
